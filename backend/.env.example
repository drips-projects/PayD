# Backend Configuration
PORT=3001
NODE_ENV=development

# OAuth2 Social Login Configuration
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
FRONTEND_URL=http://localhost:5173

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key
JWT_REFRESH_SECRET=your-super-secret-refresh-key

# Stellar Network Configuration
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# SDS Configuration
SDS_API_KEY=your-sds-api-key-here
SDS_ENDPOINT=https://sds-api.stellar.org
SDS_ENABLE=true

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/payd_db
DB_HOST=localhost
DB_PORT=5432
DB_USER=payd_user
DB_PASSWORD=payd_password
DB_NAME=payd_db

# Logging
LOG_LEVEL=debug

# Features
ENABLE_CACHING=true
CACHE_TTL=3600
# ORGUSD Asset Configuration (populated after running scripts/issue-orgusd.ts)
ORGUSD_ISSUER_PUBLIC=
ORGUSD_ISSUER_SECRET=
ORGUSD_DISTRIBUTION_PUBLIC=
ORGUSD_DISTRIBUTION_SECRET=

# Stablecoin Issuer Addresses
# Testnet defaults are already baked into config/assets.ts; set these only to
# override (e.g. for mainnet deployments or a custom EURC test issuer).
#
# USDC – Circle testnet default: GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5
#         Circle mainnet:        GA5ZSEJYB37JRC5AVCIA5MOP4RHTM335X2KGX3IHOJAPP5RE34K4KZVN
USDC_ISSUER_PUBLIC=
#
# EURC – Circle mainnet:        GDHU6WRG4IEQXM5NZ4BMPKOXHW76MZM4Y2IEMFDVXBSDP6SJY4ITNPP
#        (No official Circle testnet issuer; set a custom one for testnet testing)
EURC_ISSUER_PUBLIC=

# Email Notification Configuration
EMAIL_PROVIDER=resend
EMAIL_FROM_ADDRESS=noreply@payd.example.com
EMAIL_FROM_NAME=PayD Payroll System

# Resend Configuration (if using Resend as email provider)
RESEND_API_KEY=re_xxxxxxxxxxxxx

# SendGrid Configuration (if using SendGrid as email provider)
SENDGRID_API_KEY=SG.xxxxxxxxxxxxx

# Notification Queue Configuration
NOTIFICATION_QUEUE_NAME=payment-notifications
NOTIFICATION_RETRY_ATTEMPTS=3
NOTIFICATION_RETRY_DELAY=5000

# Stellar Explorer URL
STELLAR_EXPLORER_URL=https://stellar.expert/explorer/testnet/tx

PORT=3000
DATABASE_URL=postgresql://user:password@localhost:5432/payd
NODE_ENV=development
